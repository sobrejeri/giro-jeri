# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS: URLs dos frontends ───────────────────────────
TURISTA_URL=http://localhost:5173
COOP_URL=http://localhost:5174
ADMIN_URL=http://localhost:5175

# ── Google Maps (server-side, para validações futuras) ──
GOOGLE_MAPS_API_KEY=your_server_side_key_here

# ── Pagamentos ─────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=your_mp_token_here
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret_here

# ── Notificações ───────────────────────────────────────
RESEND_API_KEY=your_resend_key_here
EMAIL_FROM=noreply@girojeri.com.br
WHATSAPP_NUMBER=5588999999999
