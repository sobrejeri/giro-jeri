{
  "name": "giro-jeri",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev":              "npm run dev --workspace=packages/api",
    "dev:api":          "npm run dev --workspace=packages/api",
    "dev:coop":         "npm run dev --workspace=packages/cooperativa",
    "dev:admin":        "npm run dev --workspace=packages/admin",
    "dev:all":          "concurrently \"npm run dev:api\" \"npm run dev:coop\" \"npm run dev:admin\"",
    "build:coop":       "npm run build --workspace=packages/cooperativa",
    "build:admin":      "npm run build --workspace=packages/admin",
    "start":            "npm run start --workspace=packages/api",
    "install:all":      "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
